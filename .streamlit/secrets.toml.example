# ───────────────────────────────────────────────────────────────
# 🔑 GEMINI API KEY  (cho khung chat AI ở cả 3 tầng)
# Cách lấy: vào https://aistudio.google.com/app/apikey  (miễn phí, có quota)
# ───────────────────────────────────────────────────────────────
# 1. Đổi tên file này thành  .streamlit/secrets.toml
# 2. Dán API key vào dòng dưới
# 3. Khởi động lại app: streamlit run app.py

GEMINI_API_KEY = "PASTE_YOUR_API_KEY_HERE"

# (Tuỳ chọn) Đổi model nếu quota của project không hỗ trợ model mặc định.
# Mặc định: "gemini-flash-latest" — Google auto-route sang model flash mới nhất.
# Có thể đổi thành: "gemini-2.5-flash", "gemini-2.5-flash-lite",
# "gemini-2.0-flash", "gemini-2.0-flash-lite"…
# Liệt kê model khả dụng cho key của bạn bằng:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY"
# GEMINI_MODEL = "gemini-2.5-flash"
